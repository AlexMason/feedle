{
	"compilerOptions": {
		"jsx": "react",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "nodenext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"moduleResolution": "nodenext",
		"lib": [
			"DOM",
			"ES5",
			"ES6",
			"ES7"
		],
		"rootDir": "./src",
		"outDir": "."
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx"
	],
	"exclude": [
		"node_modules"
	]
}